# ==========================================
# Qareeb Environment Variables (Example)
# ==========================================

# ---------- Core ----------
NODE_ENV="development"
PORT="3001"
SERVERLESS="false"

# ---------- Database (Prisma) ----------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# ---------- Frontend / API ----------
NEXT_PUBLIC_API_URL="http://localhost:3001/v1"
FRONT_URL="http://localhost:3000"

# ---------- Security / JWT ----------
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_PRIVATE_KEY=""
JWT_ACCESS_PUBLIC_KEY=""
JWT_REFRESH_PRIVATE_KEY=""
JWT_REFRESH_PUBLIC_KEY=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="1d"
JWT_REFRESH_REMEMBER_TTL="30d"
JWT_ISSUER="qareeb-api"
JWT_AUDIENCE="qareeb-web"

# ---------- Cookies ----------
COOKIE_DOMAIN=""
COOKIE_SAMESITE="lax"

# ---------- CORS / HTTP ----------
CORS_ORIGIN="http://localhost:3000,https://qareeb-web-three.vercel.app"
ALLOW_VERCEL_PREVIEW="true"
REQUEST_BODY_LIMIT="1mb"

# ---------- Rate Limit ----------
THROTTLE_LIMIT_PER_MINUTE="60"

# ---------- PostGIS ----------
POSTGIS_ENABLED="false"

# ---------- Settings Encryption ----------
# Required for encrypting secret system settings stored in DB.
SETTINGS_ENCRYPTION_KEY="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# ---------- Redis ----------
REDIS_URL="redis://localhost:6379"
REDIS_KEY_PREFIX="qareeb:dev:"

# ---------- Geo / Maps ----------
GOOGLE_GEOCODING_API_KEY=""
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ---------- Realtime (Pusher) ----------
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="mt1"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"

# ---------- AI ----------
GROQ_API_KEY=""

# ---------- NextAuth (if used) ----------
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ---------- Prisma Migration Retry (build scripts) ----------
PRISMA_MIGRATE_RETRIES="5"
PRISMA_MIGRATE_RETRY_DELAY_MS="5000"

# ==========================================
# Managed from Admin Dashboard (/admin/settings)
# Do NOT keep real values in .env in production
# ==========================================
# WhatsApp (Group: WHATSAPP)
# WHAPI_ENABLED=true|false
# WHAPI_BASE_URL=https://gate.whapi.cloud
# WHAPI_TOKEN=...
# WHAPI_INSTANCE_ID=...

# Cloudinary (Group: CLOUDINARY)
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
